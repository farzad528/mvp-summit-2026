    "def multi_agent_query(question: str) -> str:\n",
    "    \"\"\"Route a question to the appropriate agent based on content.\"\"\"\n",
    "    # Simple keyword-based routing\n",
    "    policy_keywords = [\"refund\", \"claim\", \"return\", \"policy\", \"escalat\", \"contoso\", \"insurance\", \"defective\"]\n",
    "    \n",
    "    q_lower = question.lower()\n",
    "    if any(kw in q_lower for kw in policy_keywords):\n",
    "        agent = \"contoso-policy-assistant\"\n",
    "        domain = \"Contoso Policy\"\n",
    "    else:\n",
    "        agent = \"mvp-summit-concierge\"\n",
    "        domain = \"MVP Summit\"\n",
    "    \n",
    "    print(f\"[Router → {domain}]\")\n",
    "    return ask_agent(agent, question)\n",
    "\n",
    "# Test multi-agent routing\n",
    "questions = [\n",
    "    \"What AI sessions are in Building 33 on Tuesday afternoon?\",\n",
    "    \"What is the restocking fee for electronics returned after 14 days?\",\n",
    "    \"Is there a shuttle between Building 18 and Building 33?\",\n",
    "    \"What fraud detection patterns does Contoso check for?\",\n",
    "]\n",
    "\n",
    "for q in questions:\n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(f\"Q: {q}\\n\")\n",
    "    print(multi_agent_query(q))"
   ]
