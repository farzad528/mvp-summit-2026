# Azure AI Search (S1+ with semantic search enabled)
AZURE_AI_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_AI_SEARCH_KEY=              # optional — leave blank to use DefaultAzureCredential

# Azure AI Foundry project
AZURE_OPENAI_ENDPOINT=https://<your-foundry-account>.openai.azure.com/
AZURE_AI_PROJECT_ENDPOINT=https://<your-foundry-account>.services.ai.azure.com/api/projects/<your-project>

# Model deployments (must exist in your Foundry account)
MODEL_DEPLOYMENT=gpt-4.1          # or gpt-4o, gpt-4.1-mini
EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Auth: uses DefaultAzureCredential — run `az login` first
