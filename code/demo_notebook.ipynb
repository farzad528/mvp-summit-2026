    "## Part 1: Test the Knowledge Bases Directly\n",
    "\n",
    "Before using agents, let's verify both KBs work with the Azure AI Search retrieve API."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "=== MVP Summit KB ===\n",
      "Q: What sessions are about RAG?\n",
      "\n",
      "The following MVP Summit sessions are about RAG:\n",
      "\n",
      "- \"Cost Optimization for RAG Workloads\" on March 25, 2026, 13:00-14:00, Building 18, Room: St. Helens [ref_id:0].\n",
      "- \"Evaluating RAG Quality at Scale\" on March 26, 2026, 10:30-11:30, Building 33, Room: Mt. Rainier [ref_id:2].\n",
      "- \"Building Production RAG Systems with Foundry IQ\" on March 25, 2026, 09:00-10:00, Building 33, Room: Mt. Rainier [ref_id:3].\n",
      "- \"Document-Level Access Control in RAG\" on March 25, 2026, 10:30-11:30, Building 40, Room: Denali [ref_id:4].\n",
      "- \"Agentic Retrieval: Beyond Simple RAG\" on March 25, 2026, 10:30-11:30, Building 33, Room: Mt. Rainier [ref_id:6].\n",
      "- \"Context Engineering for Reliable Agents\" on March 25, 2026, 13:00-14:00, Building 33, Room: Cascades [ref_id:7].\n",
      "- \"Multimodal RAG: Chat with Your PowerPoints\" on March 25, 2026, 16:00-17:00, Building 33, Room: Olympic [ref_id:8].\n"
     ]
    }
   ],
   "source": [
    "import requests\n",
    "\n",
    "token_provider = get_bearer_token_provider(credential, \"https://search.azure.com/.default\")\n",
    "search_headers = {\"Authorization\": f\"Bearer {token_provider()}\", \"Content-Type\": \"application/json\"}\n",
    "API_VER = \"2025-11-01-preview\"\n",
    "\n",
    "def test_kb(kb_name: str, query: str):\n",
    "    \"\"\"Test a knowledge base with a direct retrieve call.\"\"\"\n",
    "    url = f\"{SEARCH_ENDPOINT}/knowledgebases/{kb_name}/retrieve?api-version={API_VER}\"\n",
    "    body = {\n",
    "        \"messages\": [{\"role\": \"user\", \"content\": [{\"type\": \"text\", \"text\": query}]}],\n",
    "        \"retrievalReasoningEffort\": {\"kind\": \"low\"}\n",
    "    }\n",
    "    resp = requests.post(url, headers=search_headers, json=body)\n",
    "    resp.raise_for_status()\n",
    "    data = resp.json()\n",
    "    # Extract answer text\n",
    "    for msg in data.get(\"response\", []):\n",
    "        for c in msg.get(\"content\", []):\n",
    "            if c.get(\"type\") == \"text\":\n",
    "                return c[\"text\"]\n",
    "    return str(data)\n",
    "\n",
    "# Test Summit KB\n",
    "print(\"=== MVP Summit KB ===\")\n",
    "print(\"Q: What sessions are about RAG?\\n\")\n",
    "answer = test_kb(\"mvp-summit-knowledge-base\", \"What sessions are about RAG?\")\n",
    "print(answer)"
   ]
  },
