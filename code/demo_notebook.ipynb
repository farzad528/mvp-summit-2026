   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Q: Write a Python function that validates a return claim...\n",
      "\n",
      "Here's a Python function, grounded in the Contoso Insurance claims and returns policy:\n",
      "\n",
      "- Approvals only within 30 days from purchase date (receipt/invoice)\n",
      "- Full refund for all conditions in first 14 days\n",
      "- 15–30 days: Like New/Good = 100%, Fair = 80%\n",
      "- Defective (as confirmed by Contoso): 100% at any time (up to 1 year)\n",
      "- If more than 30 days, generally no refund (store credit only up to 60 days, requires manager approval)\n",
      "- Item condition: Like New, Good, Fair, Defective (as described)\n",
      "- Electronic items >$500 need extra checks (not enough info here, so just note the possibility)\n",
      "- Escalation triggers: claim value > $2,500, 3+ previous claims in 12 months, safety concern, recall/partial/bundle/international/exception request\n",
      "\n",
      "```python\n",
      "from datetime import datetime\n",
      "\n",
      "def validate_return_claim(claim):\n",
      "    \"\"\"\n",
      "    Args:\n",
      "        claim: dict with keys\n",
      "            - purchase_date (YYYY-MM-DD str)\n",
      "            - claim_date (YYYY-MM-DD str)\n",
      "            - item_condition (str, one of 'Like New', 'Good', 'Fair', 'Defective')\n",
      "            - item_price (float)\n",
      "            - is_electronic (bool)\n",
      "            - is_defective (bool, must be confirmed by Contoso technician)\n",
      "            # Note: previous_claims, bundle info, international purchase, recall flag,\n",
      "            # or explicit exception request should also be inputs for complete escalation detection\n",
      "\n",
      "    Returns:\n",
      "        dict: approved (bool), refund_percentage (float), needs_escalation (bool), reason (str)\n",
      "    \"\"\"\n",
      "\n",
      "    # --- Policy-based settings ---\n",
      "    REQUIRE_WINDOW_DAYS = 30  # Normal return window\n",
      "    FULL_REFUND_DAYS = 14\n",
      "    PARTIAL_REFUND_DAYS = 30\n",
      "    STORE_CREDIT_MAX_DAYS = 60\n",
      "    DEFECTIVE_MAX_DAYS = 365  # 1 year\n",
      "\n",
      "    approved = False\n",
      "    refund_percentage = 0.0\n",
      "    needs_escalation = False\n",
      "    reason = ''\n",
      "\n",
      "    try:\n",
      "        purchase = datetime.strptime(claim['purchase_date'], '%Y-%m-%d')\n",
      "        claim_d = datetime.strptime(claim['claim_date'], '%Y-%m-%d')\n",
      "        days_since_purchase = (claim_d - purchase).days\n",
      "\n",
      "        # DEFECTIVE Items\n",
      "        if claim.get('is_defective', False):\n",
      "            if 0 <= days_since_purchase <= DEFECTIVE_MAX_DAYS:\n",
      "                approved = True\n",
      "                refund_percentage = 1.0\n",
      "                reason = 'Defective item (confirmed by Contoso technician) — full refund applies【4:0†source】【4:1†source】【4:5†source】.'\n",
      "            else:\n",
      "                reason = 'Defective claim outside of 1-year window.'\n",
      "            # Escalation: high value/other conditions must still be checked\n",
      "        else:\n",
      "            # Non-defective items\n",
      "            if days_since_purchase < 0:\n",
      "                reason = \"Claim date is before purchase date.\"\n",
      "            elif days_since_purchase <= FULL_REFUND_DAYS:\n",
      "                approved = True\n",
      "                refund_percentage = 1.0\n",
      "                reason = 'All returns within 14 days get full refund (all conditions)【4:1†source】【4:5†source】.'\n",
      "            elif days_since_purchase <= PARTIAL_REFUND_DAYS:\n",
      "                if claim['item_condition'] in ['Like New', 'Good']:\n",
      "                    approved = True\n",
      "                    refund_percentage = 1.0\n",
      "                    reason = f\"{claim['item_condition']} condition within 30 days — full refund【4:1†source】【4:5†source】.\"\n",
      "                elif claim['item_condition'] == 'Fair':\n",
      "                    approved = True\n",
      "                    refund_percentage = 0.8\n",
      "                    reason = 'Fair condition within 15-30 days — 80% refund【4:1†source】【4:5†source】.'\n",
      "                else:\n",
      "                    reason = f\"Ineligible item condition: {claim['item_condition']}【4:0†source】【4:5†source】.\"\n",
      "            elif days_since_purchase <= STORE_CREDIT_MAX_DAYS:\n",
      "                approved = False  # Store credit, requires manager approval (not auto-approved)\n",
      "                refund_percentage = 0.5\n",
      "                reason = 'Eligible only for store credit (50%) with manager approval — see escalation【4:1†source】.'\n",
      "                needs_escalation = True\n",
      "            else:\n",
      "                reason = 'Return window expired — no refund per policy【4:1†source】【4:5†source】.'\n",
      "\n",
      "        # --- Escalation triggers ---\n",
      "        if claim['item_price'] > 2500:\n",
      "            needs_escalation = True\n",
      "            reason += ' Escalation required: Claim value exceeds $2,500【4:3†source】.'\n",
      "        # Note: without more data, cannot check prior claims, recall, bundle/kit/partial, exception, or international\n",
      "\n",
      "        # Specific check for electronics >$500, must flag for additional requirements (but info not sufficient here)\n",
      "        if claim['is_electronic'] and claim['item_price'] > 500:\n",
      "            reason += ' Electronics over $500 require charger/cables, serial verification, and restocking fee beyond 14 days if not defective【4:1†source】.'\n",
      "    except Exception as e:\n",
      "        return {\n",
      "            'approved': False,\n",
      "            'refund_percentage': 0.0,\n",
      "            'needs_escalation': False,\n",
      "            'reason': f'Error in claim data: {e}'\n",
      "        }\n",
      "\n",
      "    return {\n",
      "        'approved': approved,\n",
      "        'refund_percentage': refund_percentage,\n",
      "        'needs_escalation': needs_escalation,\n",
      "        'reason': reason.strip(),\n",
      "    }\n",
